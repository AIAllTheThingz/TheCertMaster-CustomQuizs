{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "QuizAPI",
    "Audience": "QuizAPIUsers",
    "AccessTokenMinutes": 60,
    "RotateDays": 90
  },
  "Cors": {
    "AllowedOrigins": [
      "https://quiz.yourdomain.example"
    ]
  },
  "Database": {
    "AutoMigrateOnStartup": false
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 10,
      "WindowMinutes": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": false
  }
}
