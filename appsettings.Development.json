{
  "Jwt": {
    "Issuer": "QuizAPI",
    "Audience": "QuizAPIUsers",
    "Key": "0123456789ABCDEF0123456789ABCDEF"
  },
  "Database": {
    "AutoMigrateOnStartup": false
  },
  "RateLimiting": {
    "Auth": {
      "RegisterPermitLimit": 10,
      "LoginPermitLimit": 50,
      "LoopbackPermitLimit": 250,
      "WindowMinutes": 5
    },
    "PreEmployment": {
      "GeneratePermitLimit": 200,
      "SubmitPermitLimit": 200,
      "LoopbackPermitLimit": 250,
      "WindowMinutes": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
